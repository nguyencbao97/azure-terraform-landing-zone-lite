project_name = "cloudlab"
environment  = "dev"
location     = "eastus"
owner        = "bao-nguyen"

address_space         = ["10.20.0.0/16"]
public_subnet_prefix  = ["10.20.1.0/24"]
private_subnet_prefix = ["10.20.2.0/24"]

# Phase 2 optional application workload.
# Keep false to deploy only the landing zone foundation.
# Set true when you want to deploy App Service, Application Insights, managed identity, and diagnostics.
deploy_application   = false
app_service_sku_name = "F1"
